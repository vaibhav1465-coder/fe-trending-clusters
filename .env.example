# FE Trending Clusters environment variables

USE_GOOGLE_NLP=true
GOOGLE_NLP_API_KEY=
NLP_MAX_ARTICLES=25

FE_LOOKBACK_DAYS=3
FE_MAX_ARTICLES=220
FE_MAX_CLUSTERS=12
FE_MAX_ARTICLES_PER_CLUSTER=12

# Protected refresh layer
# Public users can trigger a fresh refresh, but not repeatedly.
# 120 seconds = 2 minutes. Change to 60 if you want faster.
PUBLIC_REFRESH_COOLDOWN_SECONDS=120

# Optional admin-only override.
# Add this only in Vercel env if you want an internal secret refresh URL.
REFRESH_SECRET=
